# ═══════════════════════════════════════════════════════════════════════════
# Inner Spirit Studio — .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Environment variables & secrets ─────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules
dist
dist-ssr
*.local

# ── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel

# ── Testing & Coverage ──────────────────────────────────────────────────────
coverage
.nyc_output
test-results
playwright-report

# ── Cache & Temp ───────────────────────────────────────────────────────────
.cache
.parcel-cache
.turbo
tmp
temp
*.tmp

# ── Build artifacts ───────────────────────────────────────────────────────────
*.tsbuildinfo
next
.nuxt
.output

# ── OS generated ─────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini
