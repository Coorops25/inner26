# Inner Spirit Studio — Environment Variables
# Copy this file to .env.local and fill in your values


# --- WhatsApp Business ---
# WhatsApp number for booking redirects (no + sign, full international format)
VITE_WHATSAPP_NUMBER=573212248261

# --- Studio Info ---
VITE_STUDIO_NAME=Inner Spirit Studio
VITE_STUDIO_EMAIL=hola@innerspirit.co
VITE_STUDIO_INSTAGRAM=innerspirit_studio

# --- Booking / Calendar ---
# Optional: embed URL for scheduling tool (Cal.com, Calendly, etc.)
VITE_BOOKING_URL=
VITE_BOOKING_API_URL=

# --- Instagram Event Feed ---
# Optional: endpoint that returns posts per eventSlug
# Example: https://api.innerspirit.co/instagram/feed
VITE_IG_FEED_ENDPOINT=
# Optional: public profile URL
VITE_IG_PROFILE_URL=https://instagram.com/innerspirit_studio

# --- Analytics ---
# Optional: Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=
