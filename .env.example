# Inner Spirit Studio — Environment Variables
# Copy this file to .env.local and fill in your values


# --- WhatsApp Business ---
# WhatsApp number for booking redirects (no + sign, full international format)
VITE_WHATSAPP_NUMBER=573000000000

# --- Studio Info ---
VITE_STUDIO_NAME=Inner Spirit Studio
VITE_STUDIO_EMAIL=hola@innerspirit.co
VITE_STUDIO_INSTAGRAM=innerspirit_studio

# --- Booking / Calendar ---
# Optional: embed URL for scheduling tool (Cal.com, Calendly, etc.)
VITE_BOOKING_URL=
VITE_BOOKING_API_URL=

# --- Payments / Orders (server-only; configure in Vercel, do not prefix with VITE) ---
PUBLIC_SITE_URL=https://innerspirit.co
ORDER_TOKEN_SECRET=replace-with-long-random-order-token-secret
DATABASE_URL=postgres://user:password@host:5432/inner
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=

# Mercado Pago Checkout Pro
MERCADOPAGO_ACCESS_TOKEN=replace-with-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=replace-with-mercadopago-webhook-secret

# Wompi Checkout Web
WOMPI_PUBLIC_KEY=replace-with-wompi-public-key
WOMPI_INTEGRITY_KEY=replace-with-wompi-integrity-key
WOMPI_EVENTS_SECRET=replace-with-wompi-events-secret
WOMPI_BASE_URL=https://production.wompi.co/v1
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# Email confirmation with PDF attachment
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Inner Spirit Studio <hola@innerspirit.co>
STUDIO_NOTIFY_EMAIL=hola@innerspirit.co

# --- Instagram Event Feed ---
# Optional: endpoint that returns posts per eventSlug
# Example: https://api.innerspirit.co/instagram/feed
VITE_IG_FEED_ENDPOINT=
# Optional: public profile URL
VITE_IG_PROFILE_URL=https://instagram.com/innerspirit_studio

# --- Analytics ---
# Optional: Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=
